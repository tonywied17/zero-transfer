{
  "name": "@zero-transfer/sdk",
  "version": "0.1.0-alpha.0",
  "description": "Protocol-neutral TypeScript file transfer SDK for Node.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run test:coverage && npm run build && npm run pack:dry",
    "docs": "typedoc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration:ftp": "vitest run test/integration/ftpProvider.docker.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ftp",
    "ftps",
    "sftp",
    "zero-transfer",
    "client",
    "sdk",
    "typescript",
    "file-transfer",
    "mft",
    "webdav",
    "s3",
    "upload",
    "download",
    "streams"
  ],
  "author": "Tony Wiedman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonywied17/zero-transfer.git"
  },
  "bugs": {
    "url": "https://github.com/tonywied17/zero-transfer/issues"
  },
  "homepage": "https://github.com/tonywied17/zero-transfer#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "provenance": true,
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
